#!/usr/bin/make -f

# for debian/reform-tools.install and for dkms
include /usr/share/dpkg/pkg-info.mk
export DEB_VERSION_UPSTREAM

%:
	dh $@

execute_after_dh_auto_build:
	for d in Desktop Documents Downloads Music Pictures Videos; do mkdir -p etc/skel/$$d; done
	for m in full rescue; do sed "s/{DATE}/$(shell date --date=@$(SOURCE_DATE_EPOCH) --iso-8601=date)/" etc.in/motd-$$m > etc/motd-$$m; done

override_dh_installsystemd:
	dh_installsystemd --package=reform-tools reform-hw-setup.service
	dh_installsystemd --package=reform-tools --no-stop-on-upgrade --no-start reform-sleep.service

override_dh_dkms:
	dh_dkms -V $(DEB_VERSION_UPSTREAM)

execute_after_dh_clean:
	rm -f etc/motd-full etc/motd-rescue
