#!/bin/sh

set -eu

usage () {
	echo "Run synaptic as the superuser, preserving the DISPLAY environment variable" >&2
	echo "and setting up xhost such that the local root user is temporarily allowed" >&2
	echo "to talk to the current user's Xwayland." >&2
	echo >&2
	echo "Usage: $0 [--help]" >&2
	echo >&2
	echo "Options:" >&2
	echo "  --help           Display this help and exit." >&2
}

if [ "$#" -gt 0 ]; then
	if [ "$1" != "--help" ]; then
		echo "E: too many arguments" >&2
		usage
		exit 1
	fi
	usage
	exit 0
fi

finish() {
    # revoke Xwayland access
    xhost -si:localuser:root
}

trap finish EXIT INT TERM

# temporarily allow the local root user to talk to the current user's Xwayland
xhost si:localuser:root

# start synaptic as superuser through polkit (asks for authentication)
pkexec env DISPLAY="$DISPLAY" synaptic
